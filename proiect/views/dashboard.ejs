<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Files - NodeNotes</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #ffffff;
            color: #111;
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Navbar */
        .navbar-wrapper {
            display: flex;
            justify-content: center;
            padding: 20px 20px 0;
        }

        .navbar {
            background-color: #000 !important;
            border: 2px solid #000;
            border-radius: 4px;
            padding: 12px 24px;
            width: 100%;
            max-width: 960px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 700;
            font-size: 1.2rem;
            color: #fff !important;
        }

        .navbar-brand svg {
            width: 26px;
            height: 26px;
        }

        .btn-logout {
            border: 1.5px solid #fff;
            color: #fff;
            background: transparent;
            border-radius: 3px;
            font-size: 0.85rem;
            font-weight: 600;
            transition: background 0.15s, color 0.15s;
        }

        .btn-logout:hover {
            background: #fff;
            color: #000;
        }

        /* Main */
        main {
            max-width: 960px;
            margin: 0 auto;
            padding: 24px 20px 36px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
            padding-bottom: 16px;
            border-bottom: 2px solid #000;
        }

        .section-header h2 {
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0;
        }

        .new-file-form {
            display: flex;
            gap: 8px;
        }

        .new-file-form .form-control {
            border: 1.5px solid #000;
            border-radius: 3px;
            background: #fafafa;
            font-size: 0.9rem;
            min-width: 200px;
        }

        .new-file-form .form-control:focus {
            border-color: #000;
            box-shadow: 0 0 0 2px rgba(0,0,0,0.15);
            background: #fff;
        }

        .btn-create {
            background: #000;
            color: #fff;
            border: 2px solid #000;
            border-radius: 3px;
            font-weight: 600;
            font-size: 0.9rem;
            white-space: nowrap;
            padding: 6px 14px;
            cursor: pointer;
            transition: background 0.15s, color 0.15s;
        }

        .btn-create:hover {
            background: #fff;
            color: #000;
        }

        .btn-cancel {
            background: transparent;
            color: #555;
            border: 1.5px solid #aaa;
            border-radius: 3px;
            font-weight: 600;
            font-size: 0.9rem;
            white-space: nowrap;
            padding: 6px 14px;
            cursor: pointer;
            transition: border-color 0.15s, color 0.15s;
        }

        .btn-cancel:hover {
            border-color: #000;
            color: #000;
        }

        /* File cards */
        .card-file {
            background: #fff;
            border: 2px solid #000 !important;
            border-radius: 4px;
            cursor: pointer;
            transition: box-shadow 0.15s, transform 0.1s;
            padding: 18px 20px;
        }

        .card-file:hover {
            box-shadow: 4px 4px 0 #000 !important;
            transform: translateY(-2px);
        }

        .card-file h5 {
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 6px;
            color: #000;
        }

        .card-file .meta {
            font-size: 0.8rem;
            color: #555;
        }

        a.file-link {
            color: inherit;
            text-decoration: none;
            display: block;
        }

        .btn-delete {
            border: 1.5px solid #dc3545;
            color: #dc3545;
            background: transparent;
            border-radius: 3px;
            font-size: 0.8rem;
            font-weight: 600;
            width: 100%;
            margin-top: 6px;
            transition: background 0.15s, color 0.15s;
        }

        .btn-delete:hover {
            background: #dc3545;
            color: #fff;
        }

        .empty-state {
            border: 2px dashed #bbb;
            border-radius: 4px;
            padding: 48px 24px;
            text-align: center;
            color: #777;
        }

        .empty-state svg {
            width: 48px;
            height: 48px;
            margin-bottom: 16px;
            opacity: 0.4;
        }
    </style>
</head>
<body>

    <div class="navbar-wrapper">
    <nav class="navbar">
        <span class="navbar-brand">
            <!-- Notebook icon -->
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="8" y="4" width="24" height="32" rx="2" fill="#fff" stroke="#fff" stroke-width="2"/>
                <rect x="8" y="4" width="6" height="32" rx="2" fill="#ccc" stroke="#ccc" stroke-width="2"/>
                <line x1="18" y1="13" x2="28" y2="13" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="18" y1="19" x2="28" y2="19" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="18" y1="25" x2="28" y2="25" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            NodeNotes
        </span>
        <div class="d-flex align-items-center gap-3">
            <span style="color:#ccc; font-size:0.9rem;">Hello, <strong style="color:#fff"><%= currentUser %></strong></span>
            <form action="/logout" method="POST" class="m-0">
                <button class="btn-logout" type="submit">Log Out</button>
            </form>
        </div>
    </nav>
    </div>

    <main>
        <div class="section-header">
            <h2>My Files</h2>
            <div class="d-flex align-items-center gap-2">
                <form action="/files" method="POST" class="new-file-form" id="new-file-form" style="display:none !important;">
                    <input type="text" name="name" class="form-control" id="new-file-input" placeholder="New file name" required>
                    <button class="btn-create" type="submit">Save</button>
                    <button type="button" class="btn-cancel" onclick="toggleNewFile(false)">Cancel</button>
                </form>
                <button class="btn-create" id="btn-show-create" onclick="toggleNewFile(true)">+ Create</button>
            </div>
        </div>

        <% if (files.length === 0) { %>
            <div class="empty-state">
                <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="8" y="4" width="24" height="32" rx="2" fill="#fff" stroke="#000" stroke-width="2"/>
                    <rect x="8" y="4" width="6" height="32" rx="2" fill="#f0f0f0" stroke="#000" stroke-width="2"/>
                    <line x1="18" y1="13" x2="28" y2="13" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
                    <line x1="18" y1="19" x2="28" y2="19" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
                    <line x1="18" y1="25" x2="28" y2="25" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <p class="mb-0">No files yet. Create your first one above.</p>
            </div>
        <% } else { %>
            <div class="row g-3">
                <% files.forEach(function(f) { %>
                    <div class="col-md-4">
                        <a class="file-link" href="/canvas/<%= f._id %>">
                            <div class="card-file shadow-sm">
                                <h5><%= f.name %></h5>
                                <div class="meta">
                                    <span><%= f.nodes.length %> node<%= f.nodes.length !== 1 ? 's' : '' %></span> &middot;
                                    <span><%= f.edges.length %> connection<%= f.edges.length !== 1 ? 's' : '' %></span>
                                </div>
                                <div class="meta">Updated: <%= f.updatedAt.toLocaleString('en-GB') %></div>
                            </div>
                        </a>
                        <form action="/files/<%= f._id %>/delete" method="POST"
                              onsubmit="return confirm('Delete \'<%= f.name %>\'?');">
                            <button type="submit" class="btn-delete">Delete</button>
                        </form>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleNewFile(show) {
            const form = document.getElementById('new-file-form');
            const btn  = document.getElementById('btn-show-create');
            if (show) {
                form.style.setProperty('display', 'flex', 'important');
                btn.style.display = 'none';
                document.getElementById('new-file-input').focus();
            } else {
                form.style.setProperty('display', 'none', 'important');
                btn.style.display = '';
                document.getElementById('new-file-input').value = '';
            }
        }
    </script>
</body>
</html>
