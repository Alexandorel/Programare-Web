<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fisierele mele - NodeNotes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #1e1e2e; color: #f5f5f5; min-height: 100vh; }
        .card-file { background: #2b2b3d; border: none; cursor: pointer; transition: transform .1s; }
        .card-file:hover { transform: translateY(-2px); background: #353550; }
        a { color: inherit; text-decoration: none; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark px-4">
        <span class="navbar-brand">NodeNotes</span>
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted">Salut, <%= currentUser %></span>
            <form action="/logout" method="POST" class="m-0">
                <button class="btn btn-sm btn-outline-light" type="submit">Logout</button>
            </form>
        </div>
    </nav>

    <main class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="m-0">Fisierele mele</h2>
            <form action="/files" method="POST" class="d-flex gap-2">
                <input type="text" name="name" class="form-control" placeholder="Nume fisier nou" required>
                <button class="btn btn-primary" type="submit">+ Creeaza</button>
            </form>
        </div>

        <% if (files.length === 0) { %>
            <div class="alert alert-secondary">Nu ai niciun fisier inca. Creeaza primul de mai sus.</div>
        <% } else { %>
            <div class="row g-3">
                <% files.forEach(function(f) { %>
                    <div class="col-md-4">
                        <a href="/canvas/<%= f._id %>">
                            <div class="card card-file p-3 shadow-sm">
                                <h5 class="mb-1"><%= f.name %></h5>
                                <small class="text-muted">
                                    <%= f.nodes.length %> noduri, <%= f.edges.length %> conexiuni
                                </small>
                                <small class="text-muted">Modificat: <%= f.updatedAt.toLocaleString('ro-RO') %></small>
                            </div>
                        </a>
                        <form action="/files/<%= f._id %>/delete" method="POST"
                              onsubmit="return confirm('Sigur stergi <%= f.name %>?');" class="mt-1">
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">Sterge</button>
                        </form>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </main>
</body>
</html>
