<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title ? title : 'NodeNotes' %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #ffffff;
            min-height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
        }

        .page-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 60px;
            padding: 40px 20px;
        }

        /* Decorative notepad on the left */
        .notepad-deco {
            display: flex;
            flex-direction: column;
            gap: 12px;
            opacity: 0.85;
        }

        .sticky-note {
            width: 180px;
            padding: 16px 18px;
            background: #fffde7;
            border: 1px solid #e0d800;
            border-top: 6px solid #f9d000;
            box-shadow: 3px 3px 8px rgba(0,0,0,0.12);
            font-size: 13px;
            color: #444;
            line-height: 1.6;
            position: relative;
            transform: rotate(-2deg);
        }

        .sticky-note:nth-child(2) {
            transform: rotate(1.5deg);
            background: #e8f5e9;
            border-color: #81c784;
            border-top-color: #43a047;
        }

        .sticky-note:nth-child(3) {
            transform: rotate(-1deg);
            background: #e3f2fd;
            border-color: #90caf9;
            border-top-color: #1e88e5;
        }

        .sticky-note::before {
            content: '';
            display: block;
            width: 100%;
            height: 1px;
            background: rgba(0,0,0,0.08);
            margin-bottom: 8px;
        }

        /* Register card */
        .login-card {
            width: 100%;
            max-width: 400px;
            background-color: #ffffff;
            border: 2px solid #000000;
            border-radius: 4px;
            padding: 36px 32px;
        }

        .card-header-area {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 28px;
            padding-bottom: 16px;
            border-bottom: 2px solid #000;
        }

        .notebook-icon {
            width: 40px;
            height: 40px;
            flex-shrink: 0;
        }

        .card-header-area h3 {
            margin: 0;
            font-size: 1.4rem;
            font-weight: 700;
            color: #000;
            letter-spacing: -0.3px;
        }

        .form-label {
            font-weight: 600;
            color: #111;
            font-size: 0.9rem;
        }

        .form-control {
            border: 1.5px solid #000;
            border-radius: 3px;
            background-color: #fafafa;
        }

        .form-control:focus {
            border-color: #000;
            box-shadow: 0 0 0 2px rgba(0,0,0,0.15);
            background-color: #fff;
        }

        .btn-register {
            background-color: #000;
            color: #fff;
            border: 2px solid #000;
            border-radius: 3px;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: background 0.15s, color 0.15s;
        }

        .btn-register:hover {
            background-color: #fff;
            color: #000;
        }

        .btn-outline-dark {
            border: 2px solid #000;
            border-radius: 3px;
            font-weight: 600;
        }

        hr {
            border-color: #000;
            opacity: 0.2;
        }

        @media (max-width: 768px) {
            .notepad-deco { display: none; }
            .page-wrapper { justify-content: center; }
        }
    </style>
</head>
<body>

    <div class="page-wrapper">

        <!-- Decorative sticky notes -->
        <div class="notepad-deco">
            <div class="sticky-note">
                Buy milk<br>
                Call dentist<br>
                Fix bug #42
            </div>
            <div class="sticky-note">
                Meeting at 3pm<br>
                Review PR<br>
                Deploy to prod
            </div>
            <div class="sticky-note">
                Read chapter 5<br>
                Write unit tests<br>
                Update docs
            </div>
        </div>

        <!-- Register form -->
        <div class="login-card">

            <div class="card-header-area">
                <!-- Notebook SVG icon -->
                <svg class="notebook-icon" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="8" y="4" width="24" height="32" rx="2" fill="#fff" stroke="#000" stroke-width="2"/>
                    <rect x="8" y="4" width="6" height="32" rx="2" fill="#f0f0f0" stroke="#000" stroke-width="2"/>
                    <line x1="18" y1="13" x2="28" y2="13" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
                    <line x1="18" y1="19" x2="28" y2="19" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
                    <line x1="18" y1="25" x2="28" y2="25" stroke="#000" stroke-width="1.5" stroke-linecap="round"/>
                    <circle cx="11" cy="11" r="1.5" fill="#000"/>
                    <circle cx="11" cy="20" r="1.5" fill="#000"/>
                    <circle cx="11" cy="29" r="1.5" fill="#000"/>
                </svg>
                <h3>Create an Account</h3>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger" role="alert">
                    <%= error %>
                </div>
            <% } %>

            <form action="/register" method="POST">

                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="username" name="username" placeholder="Choose a username" required>
                </div>

                <div class="mb-4">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password" name="password" placeholder="Choose a password" required minlength="6">
                    <div class="form-text" style="color:#555; font-size:0.8rem;">Minimum 6 characters.</div>
                </div>

                <button type="submit" class="btn btn-register w-100 mb-3">Create Account</button>

                <hr class="my-4">

                <div class="text-center">
                    <p class="text-muted mb-2" style="font-size:0.9rem;">Already have an account?</p>
                    <a href="/login" class="btn btn-outline-dark w-100">Log In</a>
                </div>

            </form>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
